<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml"
      xmlns:b="http://www.google.com/2008/blogger"
      xmlns:expr="http://www.google.com/2008/expr">
<head>
  <!-- Meta y título -->
  <b:if cond='data:blog.pageType == "index"'>
    <title><data:blog.title/></title>
  </b:if>
  <b:if cond='data:blog.pageType != "index"'>
    <title><data:blog.title/> - <b:pageTitle/></title>
  </b:if>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  
  <!-- Meta para instalación tipo app -->
  <meta name="apple-mobile-web-app-capable" content="yes"/>
  <meta name="apple-mobile-web-app-status-bar-style" content="default"/>
  <meta name="apple-mobile-web-app-title" content="Mi Biblia"/>
  <meta name="mobile-web-app-capable" content="yes"/>
  <meta name="theme-color" content="#2c3e50"/>
  <link rel="apple-touch-icon" href="https://example.com/favicon-192.png"/>
  <link rel="icon" type="image/png" sizes="192x192" href="https://example.com/favicon-192.png"/>
  
  <!-- Fuente Inter -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&amp;display=swap" rel="stylesheet"/>
  
  <!-- Tailwind CSS (browser version) -->
  <script src="https://unpkg.com/@tailwindcss/browser@4"></script>
  
  <!-- Skin de Blogger (placeholder) -->
  <b:skin/>
</head>
<body class="bg-white text-gray-900" style="font-family:'Inter',sans-serif;">
  <!-- Header -->
  <header class="bg-indigo-800 text-white p-4 flex flex-col items-center">
    <h1 class="text-2xl font-bold"><data:blog.title/></h1>
    <p class="text-sm"><data:blog.description/></p>
  </header>
  
  <!-- Navegación de escritorio -->
  <nav class="bg-gray-100 p-2 hidden md:flex justify-around items-center">
    <a href="/" class="flex flex-col items-center text-gray-700 hover:text-gray-900">
      <img src="https://unpkg.com/lucide-static@latest/icons/home.svg" alt="Inicio" width="24" height="24"/>
      <span class="text-xs">Inicio</span>
    </a>
    <a href="/p/leer-hoy.html" class="flex flex-col items-center text-gray-700 hover:text-gray-900">
      <img src="https://unpkg.com/lucide-static@latest/icons/book-open.svg" alt="Leer hoy" width="24" height="24"/>
      <span class="text-xs">Leer hoy</span>
    </a>
    <a href="/p/planes.html" class="flex flex-col items-center text-gray-700 hover:text-gray-900">
      <img src="https://unpkg.com/lucide-static@latest/icons/list.svg" alt="Planes" width="24" height="24"/>
      <span class="text-xs">Planes</span>
    </a>
    <a href="/p/biblia.html" class="flex flex-col items-center text-gray-700 hover:text-gray-900">
      <img src="https://unpkg.com/lucide-static@latest/icons/book.svg" alt="Biblia" width="24" height="24"/>
      <span class="text-xs">Biblia</span>
    </a>
    <a href="/p/mi-espacio.html" class="flex flex-col items-center text-gray-700 hover:text-gray-900">
      <img src="https://unpkg.com/lucide-static@latest/icons/user.svg" alt="Mi espacio" width="24" height="24"/>
      <span class="text-xs">Mi espacio</span>
    </a>
  </nav>
  
  <!-- Navegación inferior móvil (icons en fila horizontal) -->
  <nav class="bg-gray-100 p-2 fixed bottom-0 left-0 right-0 flex justify-around items-center md:hidden">
    <a href="/" class="flex items-center text-gray-700 hover:text-gray-900" title="Inicio">
      <img src="https://unpkg.com/lucide-static@latest/icons/home.svg" alt="Inicio" width="24" height="24"/>
    </a>
    <a href="/p/leer-hoy.html" class="flex items-center text-gray-700 hover:text-gray-900" title="Leer hoy">
      <img src="https://unpkg.com/lucide-static@latest/icons/book-open.svg" alt="Leer hoy" width="24" height="24"/>
    </a>
    <a href="/p/planes.html" class="flex items-center text-gray-700 hover:text-gray-900" title="Planes">
      <img src="https://unpkg.com/lucide-static@latest/icons/list.svg" alt="Planes" width="24" height="24"/>
    </a>
    <a href="/p/biblia.html" class="flex items-center text-gray-700 hover:text-gray-900" title="Biblia">
      <img src="https://unpkg.com/lucide-static@latest/icons/book.svg" alt="Biblia" width="24" height="24"/>
    </a>
    <a href="/p/mi-espacio.html" class="flex items-center text-gray-700 hover:text-gray-900" title="Mi espacio">
      <img src="https://unpkg.com/lucide-static@latest/icons/user.svg" alt="Mi espacio" width="24" height="24"/>
    </a>
  </nav>
  
  <!-- Banner de bienvenida -->
  <section class="bg-indigo-100 p-6 rounded-lg mb-4 mx-4 md:mx-8 flex flex-col items-center text-center">
    <h2 class="text-xl font-semibold text-indigo-800 mb-2">¡Bienvenido a Mi Biblia 365!</h2>
    <p class="text-gray-700 mb-4">
      Un año con la Palabra. Lee, medita y crece cada día con planes estructurados y tu versión favorita.
    </p>
    <a href="/p/leer-hoy.html"
       class="bg-indigo-600 hover:bg-indigo-700 text-white font-medium py-2 px-4 rounded-full shadow">
      <img src="https://unpkg.com/lucide-static@latest/icons/book-open.svg" alt="Leer hoy" class="inline-block w-5 h-5 mr-2"/>
      Empezar a leer hoy
    </a>
  </section>

  <!-- Versículo del día -->
  <section class="bg-white p-5 rounded-lg shadow-md mb-4 mx-4 md:mx-8">
    <h3 class="text-lg font-medium text-gray-800 mb-1">Versículo del día</h3>
    <!-- El contenido será rellenado por JavaScript; aquí se muestra una plantilla -->
    <blockquote class="border-l-4 border-indigo-600 pl-3 text-gray-800 italic">
      <span id="verse-reference" class="block font-semibold mb-1">Jeremías 29:11</span>
      <span id="verse-text" class="block">“Porque yo sé los planes que tengo para vosotros, dice el Señor, planes de bienestar y no de calamidad, para daros un futuro y una esperanza.”</span>
    </blockquote>
    <p class="mt-2 text-sm text-gray-600">
      <img src="https://unpkg.com/lucide-static@latest/icons/sunrise.svg" alt="Tema" class="inline-block w-4 h-4 mr-1"/>
      Tema del mes: Propósito
    </p>
  </section>

  <!-- Contenido principal (Blogger) -->
  <main class="p-4 pt-6 pb-20 md:pb-4">
    <b:section id='main'/>
  </main>
  
  <!-- Footer -->
  <footer class="bg-indigo-800 text-white p-4 text-center">
    <p>&#169; <data:blog.year/> <data:blog.title/>. Todos los derechos reservados.</p>
  </footer>

  <!-- Script para cargar el versículo del día desde versiculos-diarios.json -->
  <script>
    // Evita errores si la página no tiene acceso a fetch (por ejemplo, en modo offline)
    (function(){
      const url = "https://cdn.jsdelivr.net/gh/tu-usuario/mibiblia365/data/versiculos-diarios.json";
      fetch(url)
        .then(r => r.ok ? r.json() : Promise.reject('Error al cargar JSON'))
        .then(data => {
          const today = new Date();
          const dayOfYear = Math.floor((today - new Date(today.getFullYear(),0,0)) / 86400000);
          // Los índices del JSON empiezan en 1, así que restamos 1
          const entry = data.find(v => v.dayOfYear === dayOfYear);
          if(entry){
            document.getElementById('verse-reference').textContent = entry.reference;
            document.getElementById('verse-text').textContent = entry.highlight;
          }
        })
        .catch(err => console.warn('Versículo del día no disponible:', err));
    })();
  </script>
</body>
</html>