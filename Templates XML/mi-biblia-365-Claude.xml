<!-- ============================================================
     BOOTSTRAP JS — tema, router mínimo, carga de módulos por página
     El resto de la lógica vive en JS externo (jsDelivr).
     ============================================================ -->
<script>
//<![CDATA[
(function () {
  'use strict';

  // === 1) Configuración global ===
  window.MB365 = window.MB365 || {};
  MB365.config = {
    cdnBase: 'https://cdn.jsdelivr.net/gh/USUARIO/mibiblia365@main',
    dataBase: 'https://cdn.jsdelivr.net/gh/USUARIO/mibiblia365@main/data',
    apiPrimary: 'https://docs-bible-api.netlify.app/api',
    apiFallback: 'https://api.scripture.api.bible/v1',
    defaultVersion: 'rv1960',
    version: '0.1.0-mvp'
  };

  // === 2) Tema claro/oscuro (persistente) ===
  var THEME_KEY = 'mb365.theme';
  function applyTheme(t) {
    document.documentElement.setAttribute('data-theme', t);
    try { localStorage.setItem(THEME_KEY, t); } catch (e) {}
  }
  var saved = null;
  try { saved = localStorage.getItem(THEME_KEY); } catch (e) {}
  var prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
  applyTheme(saved || (prefersDark ? 'dark' : 'light'));

  document.addEventListener('click', function (e) {
    var btn = e.target.closest && e.target.closest('#btn-theme');
    if (!btn) return;
    var curr = document.documentElement.getAttribute('data-theme');
    applyTheme(curr === 'dark' ? 'light' : 'dark');
  });

  // === 3) Router por URL (Blogger no es SPA) ===
  var ROUTES = {
    '/':                        'home',
    '/p/leer-hoy.html':         'leer-hoy',
    '/p/planes.html':           'planes',
    '/p/plan-completo.html':    'plan-completo',
    '/p/biblia.html':           'biblia',
    '/p/buscar.html':           'buscar',
    '/p/mi-espacio.html':       'mi-espacio',
    '/p/acerca.html':           'acerca',
    '/p/preguntas-frecuentes.html': 'faq',
    '/p/instalar.html':         'instalar'
  };

  function currentRoute() {
    var path = location.pathname.replace(/\/+$/, '') || '/';
    return ROUTES[path] || ROUTES[path + '.html'] || 'home';
  }

  // Marcar ítem activo en las navs
  function highlightNav() {
    var path = location.pathname;
    document.querySelectorAll('.nav-mobile a, .nav-desktop a').forEach(function (a) {
      var href = a.getAttribute('href');
      if (!href) return;
      if (href === path || (href === '/' && (path === '/' || path === ''))) {
        a.classList.add('active');
      }
    });
  }

  // === 4) Cargador de módulo de página ===
  function loadPage(pageName) {
    var url = MB365.config.cdnBase + '/js/pages/' + pageName + '.js?v=' + MB365.config.version;
    return new Promise(function (resolve, reject) {
      var s = document.createElement('script');
      s.src = url;
      s.async = true;
      s.onload = resolve;
      s.onerror = function () { reject(new Error('No se pudo cargar ' + pageName)); };
      document.head.appendChild(s);
    });
  }

  // === 5) Fallback cuando el módulo externo aún no existe (MVP) ===
  function renderFallback(pageName) {
    var app = document.getElementById('app');
    if (!app) return;
    var titles = {
      'home':         'Inicio',
      'leer-hoy':     'Leer hoy',
      'planes':       'Planes de lectura',
      'plan-completo':'Plan completo',
      'biblia':       'Biblia',
      'buscar':       'Buscar',
      'mi-espacio':   'Mi espacio',
      'acerca':       'Acerca del proyecto',
      'faq':          'Preguntas frecuentes',
      'instalar':     'Instalar como app'
    };
    var t = titles[pageName] || 'Mi Biblia 365';
    app.innerHTML =
      '<section class="card card-accent">' +
        '<p class="verse-ref" style="color: rgba(255,255,255,.8)">Salmos 119:105</p>' +
        '<p class="verse-text">Lámpara es a mis pies tu palabra, y lumbrera a mi camino.</p>' +
        '<p class="muted">Reina Valera 1960</p>' +
      '</section>' +
      '<section class="card">' +
        '<h1>' + t + '</h1>' +
        '<p class="muted">Esta página está en construcción. El módulo JS externo aún no está publicado en jsDelivr.</p>' +
        '<a href="/p/leer-hoy.html" class="btn btn-primary btn-block" style="margin-top:16px">Leer hoy</a>' +
      '</section>';
  }

  // === 6) Inicialización ===
  document.addEventListener('DOMContentLoaded', function () {
    highlightNav();
    var page = currentRoute();

    loadPage(page).catch(function () {
      // Si el módulo no existe todavía, renderiza el fallback del MVP.
      renderFallback(page);
    });
  });
})();
//]]>
</script>

